# Valhalla CRM — production env for docker-compose. Copy to .env and fill in.
#   cp .env.example .env

# URL pública donde se sirve la app. Para probar por IP: http://TU_IP_DROPLET:3000
# Con dominio + HTTPS (reverse proxy): https://crm.tudominio.com
SERVER_URL=http://localhost:3000

# Secreto de la app (JWT/sesiones). Generá uno con:
#   openssl rand -base64 32
APP_SECRET=CAMBIAME_openssl_rand_base64_32

# Postgres (la DB corre en el contenedor 'db'). Generá una password:
#   openssl rand -base64 24
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=CAMBIAME_openssl_rand_base64_24

# --- Email (opcional pero recomendado: invitaciones / reset de password) ---
# Descomentá también el bloque EMAIL_* en docker-compose.yml
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
